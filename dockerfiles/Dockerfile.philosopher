FROM ubuntu:24.04
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3-pip libgomp1 zlib1g wget unzip \
    && rm -rf /var/lib/apt/lists/*
RUN wget -q "https://github.com/Nesvilab/philosopher/releases/download/v5.1.0/philosopher_v5.1.0_linux_amd64.zip" \
    -O /tmp/philosopher.zip \
    && unzip -q /tmp/philosopher.zip -d /tmp/philosopher_dir/ \
    && mv /tmp/philosopher_dir/philosopher /usr/local/bin/philosopher \
    && chmod +x /usr/local/bin/philosopher \
    && rm -rf /tmp/philosopher.zip /tmp/philosopher_dir
RUN pip3 install boto3 azure-storage-blob azure-identity --break-system-packages --no-cache-dir
COPY omnibioai-tool-runtime/tools /app/tools
COPY omnibioai-tool-runtime/omni_tool_runtime /app/omni_tool_runtime
COPY omnibioai-tool-runtime/pyproject.toml /app/pyproject.toml
WORKDIR /app
RUN pip3 install -e . --break-system-packages
CMD ["python3", "-m", "tools.generic_sif_runner.run"]
