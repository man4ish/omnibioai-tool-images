FROM ubuntu:24.04
RUN apt-get update && apt-get install -y \
    r-base \
    r-base-dev \
    libcurl4-openssl-dev \
    libssl-dev \
    libxml2-dev \
    && R -e "install.packages('BiocManager', repos='https://cran.r-project.org')" \
    && R -e "BiocManager::install('edgeR')"
CMD ["Rscript", "-e", "library(edgeR); cat('edgeR ready\n')"]
