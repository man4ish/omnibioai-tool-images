FROM python:3.11-bookworm AS builder
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ make wget && rm -rf /var/lib/apt/lists/*
RUN wget -q https://github.com/jenniferlu717/Bracken/archive/refs/tags/v2.9.tar.gz \
    -O /tmp/bracken.tar.gz \
    && tar -xzf /tmp/bracken.tar.gz -C /tmp/ \
    && cd /tmp/Bracken-2.9/src && make \
    && cp /tmp/Bracken-2.9/src/kmer2read_distr /tmp/kmer2read_distr \
    && cp /tmp/Bracken-2.9/bracken /tmp/bracken \
    && cp /tmp/Bracken-2.9/bracken-build /tmp/bracken-build \
    && cp /tmp/Bracken-2.9/src/est_abundance.py /tmp/est_abundance.py

FROM python:3.11-slim-bookworm
COPY --from=builder /tmp/kmer2read_distr /usr/local/bin/kmer2read_distr
COPY --from=builder /tmp/bracken /usr/local/bin/bracken
COPY --from=builder /tmp/bracken-build /usr/local/bin/bracken-build
COPY --from=builder /tmp/est_abundance.py /usr/local/bin/est_abundance.py
RUN chmod +x /usr/local/bin/bracken /usr/local/bin/bracken-build /usr/local/bin/kmer2read_distr
RUN pip install boto3 azure-storage-blob azure-identity --no-cache-dir
COPY omnibioai-tool-runtime/tools /app/tools
COPY omnibioai-tool-runtime/omni_tool_runtime /app/omni_tool_runtime
COPY omnibioai-tool-runtime/pyproject.toml /app/pyproject.toml
WORKDIR /app
RUN pip install -e . --no-cache-dir
CMD ["python", "-m", "tools.generic_sif_runner.run"]
