FROM ubuntu:24.04
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    libgl1 \
    libglib2.0-0 \
    && pip3 install --break-system-packages \
    cellpose \
    torch \
    numpy \
    tifffile \
    imageio \
    matplotlib
CMD ["python3", "-m", "cellpose", "--version"]
