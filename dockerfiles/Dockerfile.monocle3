FROM ubuntu:24.04
RUN apt-get update && apt-get install -y \
    r-base \
    r-base-dev \
    libcurl4-openssl-dev \
    libssl-dev \
    libxml2-dev \
    libhdf5-dev \
    libgdal-dev \
    && R -e "install.packages('BiocManager', repos='https://cran.r-project.org')" \
    && R -e "BiocManager::install(c('monocle3','SeuratWrappers'))"
CMD ["Rscript", "-e", "library(monocle3); cat('monocle3 ready\n')"]
