FROM ubuntu:24.04
RUN apt-get update && apt-get install -y \
    r-base \
    r-base-dev \
    libcurl4-openssl-dev \
    libssl-dev \
    libxml2-dev \
    libhdf5-dev \
    && R -e "install.packages(c('Seurat','hdf5r','ggplot2'), repos='https://cran.r-project.org')"
CMD ["Rscript", "-e", "library(Seurat); cat('Seurat ready\n')"]
