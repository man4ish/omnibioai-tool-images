FROM ubuntu:24.04
RUN apt-get update && apt-get install -y \
    r-base \
    r-base-dev \
    libcurl4-openssl-dev \
    libssl-dev \
    libxml2-dev \
    && R -e "install.packages('bigstatsr', repos='https://cran.r-project.org')"
CMD ["Rscript", "-e", "library(bigstatsr); cat('bigstatsr ready\n')"]
