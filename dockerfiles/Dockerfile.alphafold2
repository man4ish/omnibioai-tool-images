FROM ubuntu:24.04
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    wget \
    git \
    && pip3 install --break-system-packages \
    torch \
    biopython \
    numpy \
    scipy \
    dm-haiku \
    ml-collections \
    absl-py \
    && git clone https://github.com/google-deepmind/alphafold.git /app/alphafold \
    && pip3 install --break-system-packages -r /app/alphafold/requirements.txt
CMD ["python3", "-c", "print('AlphaFold2 ready')"]
